{
  "openapi": "3.0.3",
  "info": {
    "title": "EXBanka 3 Gateway API",
    "version": "2026-03-25",
    "description": "Current gateway-facing route surface for the EXBanka 3 stack. Business endpoints are served through nginx on /api/v1 and routed to the underlying microservices."
  },
  "servers": [
    {
      "url": "http://localhost",
      "description": "Local nginx gateway"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Employees" },
    { "name": "Clients" },
    { "name": "Accounts" },
    { "name": "Cards" },
    { "name": "Transfers" },
    { "name": "Payments" },
    { "name": "Recipients" },
    { "name": "Exchange" },
    { "name": "Loans" },
    { "name": "Docs" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Docs"],
        "summary": "Legacy shared backend health check",
        "responses": {
          "200": { "description": "Service is reachable" }
        }
      }
    },
    "/swagger.json": {
      "get": {
        "tags": ["Docs"],
        "summary": "OpenAPI route surface served by the shared backend",
        "responses": {
          "200": { "description": "OpenAPI JSON" }
        }
      }
    },
    "/swagger-ui": {
      "get": {
        "tags": ["Docs"],
        "summary": "Swagger UI for the gateway route surface",
        "responses": {
          "200": { "description": "Swagger UI HTML" }
        }
      }
    },
